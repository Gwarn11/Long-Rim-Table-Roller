                            <button onClick={() => deleteEntity('enterprise', saved.meta.registryId)} className="px-3 py-1.5 bg-slate-800 hover:bg-red-600 text-slate-400 hover:text-white font-bold uppercase text-xs transition-colors"><i className="fa-solid fa-trash-can text-sm"></i></button>
                          </div>
