                            <div className="flex justify-between items-start mb-2"><h4 className="text-lg text-white font-black uppercase truncate mr-2">{saved.enterprise.name}</h4><span className="text-xs text-slate-500 font-mono shrink-0">{saved.meta.registryId}</span></div>
