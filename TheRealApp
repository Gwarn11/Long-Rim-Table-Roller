        const selectedName = randomFrom(names[rollD20() - 1]);
        const distList = [];
        const maxDistricts = Math.min(stationSettings.districts, districts.length);
        while(distList.length < maxDistricts) {
          const dName = districts[rollD20() - 1];
          if (!distList.includes(dName)) distList.push(dName);
        }
