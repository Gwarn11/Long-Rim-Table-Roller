                      </div>
                    </div>
                  </div>
                  <div className="lg:col-span-2 space-y-6">
                    <div className="bg-slate-900 border border-slate-800 p-6">
                      <div className="flex items-center gap-2 mb-4"><i className="fa-solid fa-briefcase text-purple-400 text-xl"></i><h3 className="text-lg text-white font-bold tracking-wider uppercase">Primary Holdings</h3></div>
                      <p className="text-slate-200 text-md leading-relaxed bg-slate-950 p-4 border border-slate-800 rounded">{enterpriseData.holdings}</p>
                    </div>
                    <div className="bg-slate-900 border-t-2 border-purple-800 p-6">
                      <div className="flex items-center gap-2 mb-4"><i className="fa-solid fa-shield-halved text-purple-400 text-xl"></i><h3 className="text-lg text-white font-bold tracking-wider uppercase">Overall Strength</h3></div>
                      <p className="text-purple-100 text-md leading-relaxed bg-purple-950/20 p-4 border border-purple-900/50 rounded">{enterpriseData.strength}</p>
                    </div>
                  </div>
                </div>
              )}
            </div>
          )}

          {/* --- STATION CONFIG MODAL --- */}
          {showStationModal && (
            <div className="fixed inset-0 bg-slate-950/90 backdrop-blur-sm flex items-center justify-center z-50 p-4">
              <div className="bg-slate-900 border-2 border-orange-600 p-6 max-w-md w-full shadow-[0_0_30px_rgba(234,88,12,0.3)] relative">
                <button onClick={() => setShowStationModal(false)} className="absolute top-4 right-4 text-slate-400 hover:text-white"><i className="fa-solid fa-xmark text-xl"></i></button>
                <h2 className="text-xl font-black text-white uppercase mb-6 flex items-center gap-2 border-b border-orange-600/50 pb-2"><i className="fa-solid fa-gear text-orange-500 text-xl"></i> Station Parameters</h2>
                <div className="space-y-6 mb-8">
                  <div><label className="flex justify-between text-xs font-bold text-slate-300 uppercase mb-2"><span>Districts</span><span className="text-orange-500">{stationSettings.districts}</span></label><input type="range" min="0" max="10" value={stationSettings.districts} onChange={(e) => setStationSettings({...stationSettings, districts: parseInt(e.target.value)})} className="w-full accent-orange-500" /></div>
                  <div><label className="flex justify-between text-xs font-bold text-slate-300 uppercase mb-2"><span>Curiosities</span><span className="text-sky-500">{stationSettings.curiosities}</span></label><input type="range" min="0" max="10" value={stationSettings.curiosities} onChange={(e) => setStationSettings({...stationSettings, curiosities: parseInt(e.target.value)})} className="w-full accent-sky-500" /></div>
                  <div><label className="flex justify-between text-xs font-bold text-slate-300 uppercase mb-2"><span>Problems</span><span className="text-red-500">{stationSettings.problems}</span></label><input type="range" min="0" max="10" value={stationSettings.problems} onChange={(e) => setStationSettings({...stationSettings, problems: parseInt(e.target.value)})} className="w-full accent-red-500" /></div>
                </div>
                <button onClick={() => { generateStation(); setShowStationModal(false); }} className="w-full py-3 bg-orange-600 hover:bg-orange-500 text-white font-bold tracking-widest uppercase transition-all shadow-[0_0_15px_rgba(234,88,12,0.4)]">Apply Configuration</button>
              </div>
            </div>
          )}

        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>

