          let minorRoll = rollD20();
          while (getPairedValue(purposes, minorRoll) === majorPurpose) minorRoll = rollD20();
          minorPurpose = getPairedValue(purposes, minorRoll);
        }

        const curioList = [];
        while(curioList.length < Math.min(stationSettings.curiosities, curiosities.length)) {
          const text = curiosities[rollD20() - 1];
          if (!curioList.includes(text)) curioList.push(text);
        }
        const probList = [];
        while(probList.length < Math.min(stationSettings.problems, problems.length)) {
          const text = problems[rollD20() - 1];
          if (!probList.includes(text)) probList.push(text);
        }

        setStationData({
          name: selectedName, districts: distList, majorPurpose, minorPurpose, 
          seed: getPairedValue(seeds, rollD20()), curiosities: curioList, problems: probList
        });

        setStationMeta({
          threat: randomFrom(["Minimal", "Elevated", "Severe", "Critical", "Unknown", "Sub-nominal"]),
          gravity: randomFrom(["0g (Null)", "0.3g (Micro)", "1.0g (Standard)", "Variable", "Rotational (0.8g)"]),
          population: randomFrom(["< 1,000 (Outpost)", "5,000 - 10,000 (Hub)", "50,000+ (Metropolis)", "Unknown (Ghost)", "Variable (Nomadic)"]),
          mannaRate: (Math.random() * 8 + 0.5).toFixed(2),
          uptime: Math.floor(Math.random() * 90000) + 1000,
          registryId: `LR-${Math.random().toString(36).substr(2, 6).toUpperCase()}`
        });
        setStationViewMode('query');
      };

      const generateNpc = () => {
        let roll1 = rollD20(), roll2 = rollD20();
        while (roll1 === roll2) roll2 = rollD20();

        const subjectName = `${randomFrom(firstNames)} "${randomFrom(callsigns)}"`;
        setNpcData({
          name: subjectName,
          descriptors: [npcDescriptors[roll1 - 1], npcDescriptors[roll2 - 1]],
          primaryOcc: npcPrimaryOcc[rollD20() - 1],
          altOcc: npcAltOcc[rollD20() - 1],
          quirk: npcQuirks[rollD20() - 1],
          motivation: `${getPairedValue(npcDesires, rollD20())} ${getPairedValue(npcObjects, rollD20())}`
        });

        setNpcMeta({
          threat: randomFrom(["Harmless", "Low", "Moderate", "High", "Lethal"]),
          bounty: Math.random() > 0.7 ? `${Math.floor(Math.random() * 50000) + 1000} Manna` : "None Listed",
